local function EaterJoin()
	if game.GameId ~= 4996049426 then 
		if game.JobId == "8f33aeb2-e280-49a1-af24-e02e803b8163" then
			local tweenService = game:GetService("TweenService")
			local targetCFrame = CFrame.new(-71.0405655, 106.477287, -2258.77197, -1, 0, 0, 0, 1, 0, 0, 0, -1)
			
			local humanoidRootPart = game.Players.LocalPlayer.Character:WaitForChild("HumanoidRootPart")
			
			local tween = tweenService:Create(humanoidRootPart, TweenInfo.new(1), {CFrame = targetCFrame})
			
			tween:Play()
		end	
	end
end	

local function feedUntil95Percent()
    local feedRemote = {
        [1] = "GiveSoul"
    }

    local useSoulRemote = {
        [1] = "UseSoul"
    }

    while true do
        if workspace.Shiki.OrbSpawn and workspace.Shiki.OrbSpawn.Feed then
            local percentStr = workspace.Shiki.OrbSpawn.Feed.ObjectText

            if percentStr then
                warn("Current percent:", percentStr)

                if percentStr == '90%' then
                    for i = 1, 2 do
                        game:GetService("ReplicatedStorage").Remotes.Server:InvokeServer(unpack(useSoulRemote))
						warn("Use Soul")
                    end
                    break
                else
                    for i = 1, 2 do
                        game:GetService("ReplicatedStorage").Remotes.Server:InvokeServer(unpack(feedRemote))
						warn("Feed Soul")
					end
                end
            else
                warn("Error getting ObjectText")
            end
        end

        wait(1)
    end
end

local function checkfunction()
    local shiki = workspace:FindFirstChild("Shiki")
	local checkEater = game.Players.LocalPlayer.Character:WaitForChild("HumanoidRootPart")
	
    if shiki then
        feedUntil95Percent()
    else
        wait(5)
        checkfunction()
    end
	
    if checkEater then
        EaterJoin()
    else
        wait(5)
        checkfunction()
    end	
end

checkfunction()

